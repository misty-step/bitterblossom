#!/usr/bin/env python3
"""Dispatch one groomed builder packet safely.

This recipe validates a payload file, refuses duplicate active build work by a
deterministic idempotency key, preflights the selected task, dispatches through
bb run with --payload-file, and prints a receipt.
"""

import argparse
import hashlib
import json
import os
import shlex
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any, Dict, List, Optional

REQUIRED_FIELDS = ["repo", "backlog", "base_ref", "branch_slug", "prompt"]
ACTIVE_STATES = {"pending", "running", "awaiting_recovery", "blocked_budget"}


def eprint(*parts: object) -> None:
    print(*parts, file=sys.stderr)


def load_payload(path: Path) -> Dict[str, Any]:
    try:
        raw = path.read_text()
    except OSError as exc:
        raise SystemExit(f"payload file {path}: cannot read: {exc}")
    try:
        value = json.loads(raw)
    except json.JSONDecodeError as exc:
        raise SystemExit(f"payload file {path}: is not valid JSON: {exc}")
    if not isinstance(value, dict):
        raise SystemExit(f"payload file {path}: top-level JSON must be an object")
    return value


def validate_required(payload: Dict[str, Any], path: Path) -> None:
    missing = []
    for field in REQUIRED_FIELDS:
        value = payload.get(field)
        if not isinstance(value, str) or not value.strip():
            missing.append(field)
    if missing:
        joined = ", ".join(f"'{f}'" for f in missing)
        raise SystemExit(f"payload file {path}: required field(s) {joined} missing or empty string")


def bb_command(raw: str) -> List[str]:
    parts = shlex.split(raw)
    if not parts:
        raise SystemExit("--bb resolved to an empty command")
    return parts


def run_bb(base: List[str], config: str, args: List[str]) -> subprocess.CompletedProcess:
    return subprocess.run(
        base + ["--config", config] + args,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def parse_json(proc: subprocess.CompletedProcess, action: str) -> Any:
    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise SystemExit(
            f"{action}: bb returned non-JSON stdout: {exc}\nstdout:\n{proc.stdout}\nstderr:\n{proc.stderr}"
        )


def idempotency_key(payload: Dict[str, Any]) -> str:
    repo = payload["repo"].strip()
    backlog = payload["backlog"].strip()
    base_ref = payload["base_ref"].strip()
    branch_slug = payload["branch_slug"].strip()
    digest = hashlib.sha256(f"{repo}\0{backlog}\0{base_ref}\0{branch_slug}".encode()).hexdigest()[:16]
    return f"build:{branch_slug}:{digest}"


def run_id(doc: Any) -> str:
    if isinstance(doc, dict):
        run = doc.get("run")
        if isinstance(run, dict) and isinstance(run.get("id"), str):
            return run["id"]
        if isinstance(doc.get("id"), str):
            return doc["id"]
    raise SystemExit(f"run receipt did not contain run id: {json.dumps(doc, sort_keys=True)}")


def active_duplicate(base: List[str], config: str, key: str) -> Optional[str]:
    listed = run_bb(base, config, ["runs", "list", "--json"])
    if listed.returncode != 0:
        eprint("runs list failed before duplicate check")
        if listed.stdout:
            eprint(listed.stdout.rstrip())
        if listed.stderr:
            eprint(listed.stderr.rstrip())
        raise SystemExit(listed.returncode)
    rows = parse_json(listed, "runs list")
    if not isinstance(rows, list):
        raise SystemExit(f"runs list receipt was not an array: {json.dumps(rows, sort_keys=True)}")
    for row in rows:
        if not isinstance(row, dict):
            continue
        if row.get("idempotency_key") == key and row.get("state") in ACTIVE_STATES:
            run = row.get("id")
            return run if isinstance(run, str) else key
    return None


def build_dispatch_payload(payload: Dict[str, Any]) -> Dict[str, Any]:
    branch_slug = payload["branch_slug"].strip()
    label = payload.get("label")
    if not isinstance(label, str) or not label.strip():
        label = branch_slug
    doc = {
        "schema_version": "bb.dispatch_job.v1",
        "repo": payload["repo"].strip(),
        "prompt": payload["prompt"],
        "model": payload.get("model"),
        "label": label.strip(),
        "branch_slug": branch_slug,
        "backlog": payload["backlog"].strip(),
        "base_ref": payload["base_ref"].strip(),
    }
    return doc


def write_temp_payload(payload: Dict[str, Any]) -> str:
    fd, path = tempfile.mkstemp(prefix="bb-build-payload-", suffix=".json")
    with os.fdopen(fd, "w") as handle:
        json.dump(payload, handle, sort_keys=True)
        handle.write("\n")
    return path


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Dispatch one groomed BB build packet with validation, duplicate refusal, and a receipt."
    )
    parser.add_argument("--config", required=True, help="BB plane directory")
    parser.add_argument("--payload-file", required=True, type=Path, help="JSON object with repo, backlog, base_ref, branch_slug, prompt, and optional model/label")
    parser.add_argument("--bb", default=os.environ.get("BB_CMD") or ("target/debug/bb" if Path("target/debug/bb").exists() else "bb"), help="bb command; may include a secret helper wrapper")
    parser.add_argument("--task", default="build", help="Manual build/dispatch task to run")
    parser.add_argument("--force", action="store_true", help="Dispatch even when the same active idempotency key exists; recorded in receipt")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable receipt")
    args = parser.parse_args()

    payload = load_payload(args.payload_file)
    validate_required(payload, args.payload_file)
    base = bb_command(args.bb)
    key = idempotency_key(payload)

    duplicate = active_duplicate(base, args.config, key)
    if duplicate and not args.force:
        eprint(f"duplicate active build {duplicate} for idempotency key {key}; pass --force to override")
        return 3

    preflight = run_bb(base, args.config, ["preflight", args.task, "--json"])
    if preflight.returncode != 0:
        eprint("preflight failed before build dispatch")
        if preflight.stdout:
            eprint(preflight.stdout.rstrip())
        if preflight.stderr:
            eprint(preflight.stderr.rstrip())
        return preflight.returncode

    dispatch_payload = build_dispatch_payload(payload)
    temp_path = write_temp_payload(dispatch_payload)
    try:
        proc = run_bb(
            base,
            args.config,
            ["run", args.task, "--idempotency-key", key, "--payload-file", temp_path, "--json"],
        )
    finally:
        try:
            os.unlink(temp_path)
        except OSError:
            pass
    if proc.returncode != 0:
        eprint("build dispatch failed")
        if proc.stdout:
            eprint(proc.stdout.rstrip())
        if proc.stderr:
            eprint(proc.stderr.rstrip())
        return proc.returncode
    doc = parse_json(proc, f"run {args.task}")
    rid = run_id(doc)

    safe_next = f"bb --config {shlex.quote(args.config)} logs -f {shlex.quote(rid)}"
    receipt = {
        "run": rid,
        "task": args.task,
        "repo": payload["repo"].strip(),
        "backlog": payload["backlog"].strip(),
        "base_ref": payload["base_ref"].strip(),
        "branch_slug": payload["branch_slug"].strip(),
        "idempotency_key": key,
        "forced": args.force,
        "duplicate_active_run": duplicate,
        "watcher_command": safe_next,
        "safe_next_command": safe_next,
    }
    if args.json:
        print(json.dumps(receipt, indent=2, sort_keys=True))
    else:
        print(f"build {rid} dispatched for {receipt['backlog']} on {receipt['branch_slug']}")
        print(f"idempotency: {key}")
        print(f"safe next: {safe_next}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
