# .env.bb.example — Bitterblossom environment reference
#
# Copy to .env.bb and fill in values. Never commit the real .env.bb.
#
# Source before running the conductor or intake adapters:
#   source .env.bb
#   export GITHUB_TOKEN="$(gh auth token)"

# ─── GitHub ────────────────────────────────────────────────────────────────────

# GitHub personal access token or app installation token.
# Required for all conductor operations and the sentry_intake adapter.
# Minimum scopes: repo, read:org
GITHUB_TOKEN=

# ─── Sprite / Fly ──────────────────────────────────────────────────────────────

# Token used by bb to connect to sprite VMs.
# Use SPRITE_TOKEN (Sprite-native) or FLY_API_TOKEN (Fly.io).
SPRITE_TOKEN=
# FLY_API_TOKEN=

# ─── Sentry (for sentry_intake.py) ────────────────────────────────────────────

# Sentry API authentication token.
# Required when using --sentry-issue-id to fetch incidents from the Sentry API.
# Create at: https://sentry.io/settings/account/api/auth-tokens/
# Minimum scopes: project:read, event:read
SENTRY_AUTH_TOKEN=

# Legacy name — used as a fallback if SENTRY_AUTH_TOKEN is unset.
# SENTRY_MASTER_TOKEN=

# ─── GitHub labels (one-time setup) ───────────────────────────────────────────
#
# The sentry_intake adapter applies these labels to new issues.
# Create them in the target repo before the first run:
#
#   gh label create "source/sentry" --repo owner/repo --color "e4e669" --description "Originated from Sentry"
#   gh label create "P0" --repo owner/repo --color "b60205" --description "Critical priority"
#   gh label create "P1" --repo owner/repo --color "d93f0b" --description "High priority"
#   gh label create "P2" --repo owner/repo --color "fbca04" --description "Medium priority"
#   gh label create "P3" --repo owner/repo --color "0e8a16" --description "Low priority"
#   gh label create "bug"  --repo owner/repo --color "d73a4a" --description "Something isn't working"
